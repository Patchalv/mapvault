# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=xxx

# Mapbox
EXPO_PUBLIC_MAPBOX_TOKEN=xxx

# Google Places API
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY_IOS=xxx
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY_ANDROID=xxx

# PostHog
EXPO_PUBLIC_POSTHOG_API_KEY=xxx
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Sentry
SENTRY_AUTH_TOKEN=xxx
EXPO_PUBLIC_SENTRY_DSN=xxx

# RevenueCat
EXPO_PUBLIC_REVENUECAT_API_KEY=xxx
EXPO_PUBLIC_REVENUECAT_GOOGLE_API_KEY=xxx

# RevenueCat Webhook (server-side only — set in Supabase Edge Function secrets, NOT in .env)
# REVENUECAT_WEBHOOK_SECRET=<set via Supabase dashboard>
# REVENUECAT_SECRET_API_KEY=<set via Supabase dashboard>

# MailerLite (server-side only — set in Supabase Edge Function secrets, NOT in .env)
# MAILERLITE_API_KEY=<set via Supabase dashboard>
# MAILERLITE_GROUP_ID=<set via Supabase dashboard> (optional; subscribers are added to this group on upsert)
# SYNC_WEBHOOK_SECRET=<set via Supabase dashboard>
# SENTRY_DSN=<set via Supabase dashboard> (used by sync-to-mailerlite for error reporting)
#
# Backfill script only (not used by Edge Functions):
# Copy SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, MAILERLITE_API_KEY, and optionally MAILERLITE_GROUP_ID
# to your shell env when running scripts/backfill-mailerlite.ts
